# Пример Secret с DSN проекта Sentry. Не коммитьте реальный DSN.
#
# Создать из командной строки (предпочтительно):
#   kubectl create secret generic sentry-dsn -n demo-sentry \
#     --from-literal=dsn='https://<key>@<host>/<project>'
#
# Либо скопировать этот файл, подставить dsn и применить:
#   cp secret-sentry-dsn.yaml.example secret-sentry-dsn.yaml
#   # отредактировать stringData.dsn
#   kubectl apply -f secret-sentry-dsn.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: sentry-dsn
  namespace: demo-sentry
type: Opaque
stringData:
  dsn: "REPLACE_WITH_YOUR_SENTRY_DSN"
