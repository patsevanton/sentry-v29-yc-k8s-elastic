# Sentry + sentry-nodestore-elastic (Elasticsearch 9.x). Тег совпадает с Chart.AppVersion.
# Официальный образ: ghcr.io/getsentry/sentry
FROM ghcr.io/getsentry/sentry:26.2.1

USER root
RUN pip install --no-cache-dir --no-deps "sentry-nodestore-elastic>=1.1.0,<2" && \
    pip install --no-cache-dir "elasticsearch>=9.0.0,<10.0.0"
USER sentry
